@{
    ViewData["Title"] = "Inicio";
}

<section id="ppCarousel" class="carousel slide pp-carousel" data-bs-ride="carousel">
    <div class="carousel-indicators">
        <button type="button" data-bs-target="#ppCarousel" data-bs-slide-to="0" class="active"></button>
        <button type="button" data-bs-target="#ppCarousel" data-bs-slide-to="1"></button>
        <button type="button" data-bs-target="#ppCarousel" data-bs-slide-to="2"></button>
    </div>

    <div class="carousel-inner">
        <div class="carousel-item active pp-slide pp-slide-1">
            <div class="pp-hero-overlay">
                <div class="container">
                    <div class="pp-hero-content">
                        <h1>PERFORMANCE <span>PARTS</span></h1>
                        <p class="pp-author">by Dennis</p>
                        <h2>Calidad que mueve tu vehículo</h2>
                        <p>Repuestos automotrices con garantía, buenos precios y atención personalizada.</p>
                        <a asp-controller="Tienda" asp-action="Index" class="btn pp-btn-red">
                            Comprar ahora <i class="bi bi-arrow-right"></i>
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <div class="carousel-item pp-slide pp-slide-2">
            <div class="pp-hero-overlay">
                <div class="container">
                    <div class="pp-hero-content">
                        <h1>OFERTAS <span>PREMIUM</span></h1>
                        <p class="pp-author">hasta 40% OFF</p>
                        <h2>Repuestos seleccionados</h2>
                        <p>Encuentra filtros, frenos, baterías y lubricantes para tu vehículo.</p>
                        <a asp-controller="Tienda" asp-action="Index" class="btn pp-btn-red">
                            Ver ofertas <i class="bi bi-tags"></i>
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <div class="carousel-item pp-slide pp-slide-3">
            <div class="pp-hero-overlay">
                <div class="container">
                    <div class="pp-hero-content">
                        <h1>ENVÍOS <span>SEGUROS</span></h1>
                        <p class="pp-author">a todo el país</p>
                        <h2>Compra fácil y rápido</h2>
                        <p>Tu pedido listo con seguimiento, garantía y atención personalizada.</p>
                        <a asp-controller="Carrito" asp-action="Index" class="btn pp-btn-red">
                            Ver carrito <i class="bi bi-cart3"></i>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <button class="carousel-control-prev" type="button" data-bs-target="#ppCarousel" data-bs-slide="prev">
        <span class="carousel-control-prev-icon"></span>
    </button>

    <button class="carousel-control-next" type="button" data-bs-target="#ppCarousel" data-bs-slide="next">
        <span class="carousel-control-next-icon"></span>
    </button>
</section>

<section class="container pp-benefits">
    <div class="pp-benefit">
        <i class="bi bi-shield-check"></i>
        <div>
            <strong>Garantía asegurada</strong>
            <small>Productos de calidad</small>
        </div>
    </div>

    <div class="pp-benefit">
        <i class="bi bi-truck"></i>
        <div>
            <strong>Envíos a todo el país</strong>
            <small>Rápidos y seguros</small>
        </div>
    </div>

    <div class="pp-benefit">
        <i class="bi bi-tags"></i>
        <div>
            <strong>Precios competitivos</strong>
            <small>Ofertas especiales</small>
        </div>
    </div>

    <div class="pp-benefit">
        <i class="bi bi-headset"></i>
        <div>
            <strong>Atención al cliente</strong>
            <small>Soporte personalizado</small>
        </div>
    </div>
</section>

<section class="container mt-5">
    <div class="pp-section-title">
        <h2>Categorías principales</h2>
        <p>Encuentra repuestos según el área de tu vehículo</p>
    </div>

    <div class="row g-4">
        <div class="col-md-4 col-lg-2">
            <a asp-controller="Tienda" asp-action="Categoria" asp-route-categoria="Filtros" class="pp-category">
                <img src="/images/productos/filtro.png"
                     class="img-fluid"
                     style="height:90px; object-fit:contain;">
                <span>Filtros</span>
            </a>
        </div>

        <div class="col-md-4 col-lg-2">
            <a asp-controller="Tienda" asp-action="Categoria" asp-route-categoria="Frenos" class="pp-category">
                <img src="/images/productos/frenos.png"
                     class="img-fluid"
                     style="height:90px; object-fit:contain;">
                <span>Frenos</span>
            </a>
        </div>

        <div class="col-md-4 col-lg-2">
            <a asp-controller="Tienda" asp-action="Categoria" asp-route-categoria="Suspensión" class="pp-category">
                <img src="/images/productos/amortiguadores.png"
                     class="img-fluid"
                     style="height:90px; object-fit:contain;">
                <span>Suspensión</span>
            </a>
        </div>

        <div class="col-md-4 col-lg-2">
            <a asp-controller="Tienda" asp-action="Categoria" asp-route-categoria="Motor" class="pp-category">
                <img src="/images/productos/llanta.png"
                     class="img-fluid"
                     style="height:90px; object-fit:contain;">
                <span>Motor</span>
            </a>
        </div>

        <div class="col-md-4 col-lg-2">
            <a asp-controller="Tienda" asp-action="Categoria" asp-route-categoria="Lubricantes" class="pp-category">
                <img src="/images/productos/aceite.png"
                     class="img-fluid"
                     style="height:90px; object-fit:contain;">
                <span>Lubricantes</span>
            </a>
        </div>

        <div class="col-md-4 col-lg-2">
            <a asp-controller="Tienda" asp-action="Categoria" asp-route-categoria="Eléctrico" class="pp-category">
                <img src="/images/productos/bateria.png"
                     class="img-fluid"
                     style="height:90px; object-fit:contain;">
                <span>Eléctricos</span>
            </a>
        </div>
    </div>
</section>

<section class="container mt-5 mb-5">
    <div class="pp-section-title">
        <h2>Productos destacados</h2>
        <p>Los repuestos más buscados por nuestros clientes</p>
    </div>

    <div class="row g-4">
        <div class="col-md-6 col-lg-3">
            <div class="pp-product-card">
                <span class="pp-product-badge">Destacado</span>
                <button class="pp-fav"><i class="bi bi-heart"></i></button>

                <div class="text-center mb-3">
                    <img src="/images/productos/filtro.png"
                         class="img-fluid"
                         style="height:170px; object-fit:contain;">
                </div>

                <h5>Filtro de aceite Bosch</h5>
                <p class="pp-product-brand">Bosch</p>

                <div class="pp-stars">
                    <i class="bi bi-star-fill"></i>
                    <i class="bi bi-star-fill"></i>
                    <i class="bi bi-star-fill"></i>
                    <i class="bi bi-star-fill"></i>
                    <i class="bi bi-star-half"></i>
                    <small>(45)</small>
                </div>

                <div class="pp-product-price">Bs. 85</div>

                <a asp-controller="Tienda" asp-action="Index" class="btn pp-btn-red w-100">
                    Ver producto
                </a>
            </div>
        </div>

        <div class="col-md-6 col-lg-3">
            <div class="pp-product-card">
                <span class="pp-product-badge">Más vendido</span>
                <button class="pp-fav"><i class="bi bi-heart"></i></button>

                <div class="pp-product-icon">
                    <i class="bi bi-disc"></i>
                </div>

                <h5>Pastillas de freno</h5>
                <p class="pp-product-brand">Brembo</p>

                <div class="pp-stars">
                    <i class="bi bi-star-fill"></i>
                    <i class="bi bi-star-fill"></i>
                    <i class="bi bi-star-fill"></i>
                    <i class="bi bi-star-fill"></i>
                    <i class="bi bi-star-fill"></i>
                    <small>(32)</small>
                </div>

                <div class="pp-product-price">Bs. 180</div>

                <a asp-controller="Tienda" asp-action="Index" class="btn pp-btn-red w-100">
                    Ver producto
                </a>
            </div>
        </div>

        <div class="col-md-6 col-lg-3">
            <div class="pp-product-card">
                <span class="pp-product-badge">Nuevo</span>
                <button class="pp-fav"><i class="bi bi-heart"></i></button>

                <div class="pp-product-icon">
                    <i class="bi bi-wrench-adjustable"></i>
                </div>

                <h5>Amortiguador Monroe</h5>
                <p class="pp-product-brand">Monroe</p>

                <div class="pp-stars">
                    <i class="bi bi-star-fill"></i>
                    <i class="bi bi-star-fill"></i>
                    <i class="bi bi-star-fill"></i>
                    <i class="bi bi-star-fill"></i>
                    <i class="bi bi-star"></i>
                    <small>(27)</small>
                </div>

                <div class="pp-product-price">Bs. 350</div>

                <a asp-controller="Tienda" asp-action="Index" class="btn pp-btn-red w-100">
                    Ver producto
                </a>
            </div>
        </div>

        <div class="col-md-6 col-lg-3">
            <div class="pp-product-card">
                <span class="pp-product-badge">Oferta</span>
                <button class="pp-fav"><i class="bi bi-heart"></i></button>

                <div class="pp-product-icon">
                    <i class="bi bi-battery-charging"></i>
                </div>

                <h5>Batería 75Ah</h5>
                <p class="pp-product-brand">Willard</p>

                <div class="pp-stars">
                    <i class="bi bi-star-fill"></i>
                    <i class="bi bi-star-fill"></i>
                    <i class="bi bi-star-fill"></i>
                    <i class="bi bi-star-fill"></i>
                    <i class="bi bi-star-half"></i>
                    <small>(41)</small>
                </div>

                <div class="pp-product-price">Bs. 720</div>

                <a asp-controller="Tienda" asp-action="Index" class="btn pp-btn-red w-100">
                    Ver producto
                </a>
            </div>
        </div>
    </div>

    <div class="text-center mt-4">
        <a asp-controller="Tienda" asp-action="Index" class="btn pp-btn-dark">
            Ver tienda completa
        </a>
    </div>
</section>