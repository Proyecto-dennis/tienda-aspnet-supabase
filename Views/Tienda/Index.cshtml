@model IEnumerable<LOGIN.Models.Producto>

@{
    ViewData["Title"] = "Tienda";
}

<div class="container mt-5">
    <div class="pp-section-title">
        <h2>Tienda PERFORMANCE PARTS</h2>
        <p>Repuestos automotrices seleccionados para tu vehículo</p>
    </div>

    <div class="d-flex justify-content-center gap-2 flex-wrap mb-5">
        <a asp-action="Index" class="btn pp-btn-dark">Todos</a>
        <a asp-action="Categoria" asp-route-categoria="Motor" class="btn btn-outline-danger">Motor</a>
        <a asp-action="Categoria" asp-route-categoria="Frenos" class="btn btn-outline-danger">Frenos</a>
        <a asp-action="Categoria" asp-route-categoria="Suspensión" class="btn btn-outline-danger">Suspensión</a>
        <a asp-action="Categoria" asp-route-categoria="Transmisión" class="btn btn-outline-danger">Transmisión</a>
        <a asp-action="Categoria" asp-route-categoria="Eléctrico" class="btn btn-outline-danger">Eléctrico</a>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-warning text-center">
            No hay productos disponibles en esta categoría.
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var producto in Model)
            {
                var imagenProducto = producto.Categoria switch
                {
                    "Filtros" => "/images/productos/filtro.png",
                    "Frenos" => "/images/productos/frenos.png",
                    "Suspensión" => "/images/productos/amortiguadores.png",
                    "Lubricantes" => "/images/productos/aceite.png",
                    "Eléctrico" => "/images/productos/bateria.png",
                    "Motor" => "/images/productos/llanta.png",
                    _ => "/images/productos/filtro.png"
                };

                <div class="col-md-6 col-lg-4">
                    <div class="pp-shop-card">
                        <button class="pp-shop-fav" type="button">
                            <i class="bi bi-heart"></i>
                        </button>

                        <div class="pp-shop-img">
                            <img src="@imagenProducto" alt="@producto.Nombre" />
                        </div>

                        <div class="pp-shop-body">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <span class="pp-shop-category">@producto.Categoria</span>
                                <span class="pp-shop-brand">@producto.Marca</span>
                            </div>

                            <h5>@producto.Nombre</h5>
                            <p class="pp-shop-desc">@producto.Descripcion</p>

                            <div class="pp-stars mb-2">
                                <i class="bi bi-star-fill"></i>
                                <i class="bi bi-star-fill"></i>
                                <i class="bi bi-star-fill"></i>
                                <i class="bi bi-star-fill"></i>
                                <i class="bi bi-star-half"></i>
                                <small>(4.5)</small>
                            </div>

                            <p class="mb-2">
                                <strong>Modelo:</strong> @producto.ModeloAuto
                            </p>

                            <div class="pp-shop-price">
                                @producto.Precio.ToString("C")
                            </div>

                            <div class="mb-3">
                                @if (producto.Cantidad > 0)
                                {
                                    <span class="badge bg-success">
                                        @producto.Cantidad disponibles
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">
                                        AGOTADO
                                    </span>
                                }
                            </div>

                            @if (producto.Cantidad > 0)
                            {
                                <a asp-controller="Carrito"
                                   asp-action="Agregar"
                                   asp-route-id="@producto.Id"
                                   class="btn pp-btn-red w-100">
                                    <i class="bi bi-cart-plus-fill"></i>
                                    Agregar al carrito
                                </a>
                            }
                            else
                            {
                                <button class="btn btn-danger w-100" disabled>
                                    <i class="bi bi-ban"></i>
                                    Producto agotado
                                </button>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }

    <div class="text-center mt-5">
        <a asp-controller="Carrito" asp-action="Index" class="btn btn-success btn-lg">
            <i class="bi bi-cart"></i> Ver Carrito
        </a>
    </div>
</div>