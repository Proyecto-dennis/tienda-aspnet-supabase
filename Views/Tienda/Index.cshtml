@model IEnumerable<LOGIN.Models.Producto>

@{
    ViewData["Title"] = "Tienda de Repuestos";
}

<div class="container mt-4">
    <h2 class="text-center mb-4">🚗 Tienda de Repuestos Automotrices</h2>

    <!-- Filtros por categoría -->
    <div class="row mb-4">
        <div class="col-md-6 mx-auto">
            <div class="d-flex justify-content-center gap-2 flex-wrap">
                <a asp-action="Index" class="btn btn-outline-primary">Todos</a>
                <a asp-action="Categoria" asp-route-categoria="Motor" class="btn btn-outline-primary">Motor</a>
                <a asp-action="Categoria" asp-route-categoria="Frenos" class="btn btn-outline-primary">Frenos</a>
                <a asp-action="Categoria" asp-route-categoria="Suspensión" class="btn btn-outline-primary">Suspensión</a>
                <a asp-action="Categoria" asp-route-categoria="Transmisión" class="btn btn-outline-primary">Transmisión</a>
                <a asp-action="Categoria" asp-route-categoria="Eléctrico" class="btn btn-outline-primary">Eléctrico</a>
            </div>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-warning text-center">
            No hay productos disponibles en esta categoría.
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var producto in Model)
            {
                <div class="col-md-4 mb-4">
                    <div class="card h-100 shadow-sm">
                        <div class="card-header bg-primary text-white">
                            <span class="badge bg-light text-dark">@producto.Categoria</span>
                            <span class="badge bg-secondary float-end">@producto.Marca</span>
                        </div>
                        <div class="card-body">
                            <h5 class="card-title">@producto.Nombre</h5>
                            <p class="card-text text-muted">@producto.Descripcion</p>
                            <p class="card-text">
                                <strong>Modelo:</strong> @producto.ModeloAuto
                            </p>
                            <p class="card-text">
                                <strong>Precio:</strong> <span class="text-success fs-5">@producto.Precio.ToString("C")</span>
                            </p>
                            <p class="card-text">
                                <strong>Stock:</strong>

                                @if (producto.Cantidad > 0)
                                {
                                    <span class="badge bg-success fs-6">
                                        @producto.Cantidad disponibles
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-danger fs-6">
                                        AGOTADO
                                    </span>
                                }
                            </p>
                        </div>
                        <div class="card-footer bg-transparent">

                            @if (producto.Cantidad > 0)
                            {
                                <a asp-controller="Carrito"
                                   asp-action="Agregar"
                                   asp-route-id="@producto.Id"
                                   class="btn btn-primary w-100">

                                    <i class="bi bi-cart-plus-fill"></i>

                                    Agregar al carrito

                                </a>
                            }
                            else
                            {
                                <button class="btn btn-danger w-100" disabled>

                                    <i class="bi bi-ban"></i>

                                    Producto agotado

                                </button>
                            }

                        </div>
                    </div>
                </div>
            }
        </div>
    }

    <div class="text-center mt-4">
        <a asp-controller="Carrito" asp-action="Index" class="btn btn-success btn-lg">
            <i class="bi bi-cart"></i> Ver Carrito
        </a>
    </div>
</div>