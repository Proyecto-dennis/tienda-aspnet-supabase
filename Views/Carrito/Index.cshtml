@model List<LOGIN.Models.CarritoItem>

@{
    ViewData["Title"] = "Mi Carrito";
    var total = Model.Sum(c => c.Cantidad * c.Producto.Precio);
}

<div class="container mt-4">
    <h2 class="text-center mb-4">🛒 Mi Carrito de Compras</h2>

    @if (TempData["Mensaje"] != null)
    {
        <div class="alert alert-success">@TempData["Mensaje"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    @if (!Model.Any())
    {
        <div class="alert alert-info text-center">
            Tu carrito está vacío.
            <a asp-controller="Tienda" asp-action="Index" class="alert-link">Ir a la tienda</a>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-striped">
                <thead>
                    <tr>
                        <th>Producto</th>
                        <th>Descripción</th>
                        <th>Precio</th>
                        <th>Cantidad</th>
                        <th>Subtotal</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td><strong>@item.Producto.Nombre</strong></td>
                            <td>@item.Producto.Descripcion</td>
                            <td>@item.Producto.Precio.ToString("C")</td>
                            <td>
                                <form asp-action="ActualizarCantidad" method="post" class="d-inline">
                                    <input type="hidden" name="id" value="@item.Id" />
                                    <input type="number" name="cantidad" value="@item.Cantidad" min="1" class="form-control d-inline-block" style="width: 70px;" />
                                    <button type="submit" class="btn btn-sm btn-warning">Actualizar</button>
                                </form>
                            </td>
                            <td>@((item.Cantidad * item.Producto.Precio).ToString("C"))</td>
                            <td>
                                <a asp-action="Eliminar" asp-route-id="@item.Id" class="btn btn-danger btn-sm">
                                    <i class="bi bi-trash"></i> Eliminar
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
                <tfoot>
                    <tr>
                        <th colspan="4" class="text-end">Total:</th>
                        <th>@total.ToString("C")</th>
                        <th></th>
                    </tr>
                </tfoot>
            </table>
        </div>

        <div class="d-flex justify-content-between mt-3">
            <a asp-controller="Tienda" asp-action="Index" class="btn btn-secondary">
                <i class="bi bi-arrow-left"></i> Seguir comprando
            </a>
            <div>
                <a asp-action="Vaciar" class="btn btn-danger me-2">
                    <i class="bi bi-trash"></i> Vaciar carrito
                </a>
                <a asp-action="ConfirmarPedido" class="btn btn-success">
                    <i class="bi bi-check-circle"></i> Confirmar Pedido
                </a>
            </div>
        </div>
    }
</div>