@model List<LOGIN.Models.Pedido>

@{
    ViewData["Title"] = "Mis Pedidos";
}

<div class="container mt-4">
    <h2 class="text-center mb-4">📦 Mis Pedidos</h2>

    @if (TempData["Mensaje"] != null)
    {
        <div class="alert alert-success">@TempData["Mensaje"]</div>
    }

    @if (!Model.Any())
    {
        <div class="alert alert-info text-center">
            No tienes pedidos realizados.
            <a asp-controller="Tienda" asp-action="Index" class="alert-link">Ir a la tienda</a>
        </div>
    }
    else
    {
        @foreach (var pedido in Model)
        {
            <div class="card mb-4 shadow-sm">
                <div class="card-header bg-primary text-white">
                    <div class="row">
                        <div class="col-md-4">
                            <strong>Pedido #@pedido.Id</strong>
                        </div>
                        <div class="col-md-4 text-center">
                            <span class="badge bg-light text-dark">
                                @pedido.FechaPedido.ToString("dd/MM/yyyy HH:mm")
                            </span>
                        </div>
                        <div class="col-md-4 text-end">
                            <span class="badge @(pedido.Estado == 3 ? "bg-success" : pedido.Estado == 4 ? "bg-danger" : "bg-warning")">
                                @pedido.EstadoTexto
                            </span>
                        </div>
                    </div>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-sm">
                            <thead>
                                <tr>
                                    <th>Producto</th>
                                    <th>Cantidad</th>
                                    <th>Precio Unitario</th>
                                    <th>Subtotal</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var detalle in pedido.PedidoDetalles!)
                                {
                                    <tr>
                                        <td>@detalle.Producto?.Nombre</td>
                                        <td>@detalle.Cantidad</td>
                                        <td>@detalle.PrecioUnitario.ToString("C")</td>
                                        <td>@((detalle.Cantidad * detalle.PrecioUnitario).ToString("C"))</td>
                                    </tr>
                                }
                            </tbody>
                            <tfoot>
                                <tr>
                                    <th colspan="3" class="text-end">Total:</th>
                                    <th>@pedido.Total.ToString("C")</th>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                </div>
            </div>
        }
    }
</div>