<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Repuestos Dennis</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="manifest" href="/manifest.json">
    <meta name="theme-color" content="#2563eb">
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm">
            <div class="container">
                <a class="navbar-brand fw-bold" asp-controller="Home" asp-action="Index"><i class="bi bi-tools me-2"></i>Repuestos Dennis</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse">
                    @{
                        var usuarioNombre = Context.Session.GetString("UsuarioNombre");
                        var esAdmin = Context.Session.GetString("EsAdmin") == "true";
                     }
                    @if (!string.IsNullOrEmpty(usuarioNombre))
                    {
                        <ul class="navbar-nav me-auto">
                            <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Index">Inicio</a></li>
                            <li class="nav-item"><a class="nav-link" asp-controller="Tienda" asp-action="Index"><i class="bi bi-shop me-1"></i>Tienda</a></li>
                            <li class="nav-item"><a class="nav-link" asp-controller="Carrito" asp-action="Index"><i class="bi bi-cart me-1"></i>Carrito</a></li>
                            <li class="nav-item"><a class="nav-link" asp-controller="Pedidos" asp-action="MisPedidos"><i class="bi bi-box me-1"></i>Mis pedidos</a></li>
                            @if (esAdmin)
                            {
                                <li class="nav-item"><a class="nav-link" asp-controller="Productos" asp-action="Index"><i class="bi bi-gear me-1"></i>Admin productos</a></li>
                                <li class="nav-item"><a class="nav-link" asp-controller="Reportes" asp-action="Ganancias"><i class="bi bi-graph-up me-1"></i>Reportes</a></li>
                            }
                        </ul>
                        <div class="d-flex align-items-center gap-3 text-white">
                            <span class="small"><i class="bi bi-person-circle me-1"></i>@usuarioNombre</span>
                            <a class="btn btn-outline-light btn-sm" asp-controller="Account" asp-action="Logout">Salir</a>
                        </div>
                    }
                    else
                    {
                        <ul class="navbar-nav ms-auto">
                            <li class="nav-item"><a class="nav-link" asp-controller="Account" asp-action="Login">Iniciar sesión</a></li>
                            <li class="nav-item"><a class="btn btn-warning ms-lg-2" asp-controller="Account" asp-action="Register">Registrarse</a></li>
                        </ul>
                    }
                </div>
            </div>
        </nav>
    </header>
    <main role="main" class="container py-4">
        @RenderBody()
    </main>
    <footer class="border-top py-3 mt-5 text-center text-muted">
        <div class="container">&copy; 2026 - Repuestos Dennis | ASP.NET Core + Supabase</div>
    </footer>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
    <script>
            if ("serviceWorker" in navigator) {
                navigator.serviceWorker.register("/service-worker.js")
                    .then(() => console.log("PWA activada"))
                    .catch(error => console.log("Error PWA:", error));
            }
    </script>
</body>
</html>
