<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - PERFORMANCE PARTS</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="manifest" href="/manifest.json">
    <meta name="theme-color" content="#e30613">
</head>

<body>
    @{
        var usuarioNombre = Context.Session.GetString("UsuarioNombre");
        var esAdmin = Context.Session.GetString("EsAdmin") == "true";
    }

    <header class="pp-header">
        <div class="container">
            <div class="pp-topbar">
                <a class="pp-brand" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-tools"></i>
                    <span>
                        PERFORMANCE <strong>PARTS</strong>
                        <small>by Dennis</small>
                    </span>
                </a>

                <form class="pp-search d-none d-lg-flex" asp-controller="Tienda" asp-action="Index" method="get">
                    <input id="voiceSearchInput" type="text" name="buscar" placeholder="Buscar repuestos, marcas, categorías..." />

                    <button type="button" id="voiceSearchBtn" title="Buscar por voz">
                        <i class="bi bi-mic-fill"></i>
                    </button>

                    <button type="submit" title="Buscar">
                        <i class="bi bi-search"></i>
                    </button>
                </form>

                <div class="pp-actions">
                    @if (!string.IsNullOrEmpty(usuarioNombre))
                    {
                        <a asp-controller="Carrito" asp-action="Index" class="pp-action-link">
                            <i class="bi bi-cart3"></i>
                            <span>Carrito</span>
                        </a>

                        <div class="pp-user">
                            <i class="bi bi-person-circle"></i>
                            <span>@usuarioNombre</span>
                        </div>

                        <a class="btn btn-outline-light btn-sm" asp-controller="Account" asp-action="Logout">
                            Salir
                        </a>
                    }
                    else
                    {
                        <a class="btn btn-outline-light btn-sm" asp-controller="Account" asp-action="Login">Iniciar sesión</a>
                        <a class="btn pp-btn-red btn-sm" asp-controller="Account" asp-action="Register">Registrarse</a>
                    }
                </div>
            </div>

            <nav class="pp-nav navbar navbar-expand-lg navbar-dark">
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#ppMenu">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="ppMenu">
                    <ul class="navbar-nav me-auto">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">
                                <i class="bi bi-house-door-fill me-1"></i>Inicio
                            </a>
                        </li>

                        @if (!string.IsNullOrEmpty(usuarioNombre))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Tienda" asp-action="Index">
                                    <i class="bi bi-shop me-1"></i>Tienda
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Pedidos" asp-action="MisPedidos">
                                    <i class="bi bi-box-seam me-1"></i>Mis pedidos
                                </a>
                            </li>

                            @if (esAdmin)
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Productos" asp-action="Index">
                                        <i class="bi bi-gear-fill me-1"></i>Admin productos
                                    </a>
                                </li>

                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Reportes" asp-action="Ganancias">
                                        <i class="bi bi-graph-up-arrow me-1"></i>Reportes
                                    </a>
                                </li>
                            }
                        }
                    </ul>
                </div>
            </nav>
        </div>
    </header>

    <main role="main">
        @RenderBody()
    </main>

    <footer class="pp-footer">
        <div class="container">
            <strong>PERFORMANCE PARTS</strong>
            <span>by Dennis</span>
            <p>© 2026 - ASP.NET Core + Supabase</p>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)

    <script>
            if ("serviceWorker" in navigator) {
                navigator.serviceWorker.register("/service-worker.js")
                    .then(() => console.log("PWA activada"))
                    .catch(error => console.log("Error PWA:", error));
            }
    </script>
    <script>
            const voiceBtn = document.getElementById("voiceSearchBtn");
            const voiceInput = document.getElementById("voiceSearchInput");

            if (voiceBtn && voiceInput) {
                const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;

                if (SpeechRecognition) {
                    const recognition = new SpeechRecognition();
                    recognition.lang = "es-ES";
                    recognition.continuous = false;
                    recognition.interimResults = false;

                    voiceBtn.addEventListener("click", () => {
                        recognition.start();
                        voiceBtn.classList.add("listening");
                    });

                    recognition.onresult = function (event) {
                        const texto = event.results[0][0].transcript;
                        voiceInput.value = texto;
                        voiceBtn.classList.remove("listening");
                    };

                    recognition.onerror = function () {
                        voiceBtn.classList.remove("listening");
                        alert("No se pudo reconocer la voz. Intenta otra vez.");
                    };

                    recognition.onend = function () {
                        voiceBtn.classList.remove("listening");
                    };
                } else {
                    voiceBtn.addEventListener("click", () => {
                        alert("Tu navegador no soporta búsqueda por voz.");
                    });
                }
            }
    </script>
</body>
</html>